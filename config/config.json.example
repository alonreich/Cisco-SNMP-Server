{
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "debug": false
  },
  "snmp": {
    "community": "public",
    "timeout": 2,
    "retries": 1
  },
  "monitored_switches": [
    {
      "ip": "192.168.1.1",
      "community": "public",
      "target_type": "cisco"
    },
    {
      "ip": "192.168.1.2",
      "community": "public",
      "target_type": "vmware"
    }
  ],
  "history": {
    "retention_days": 30,
    "db_path": "database/history.db"
  },
  "logging": {
    "level": "INFO",
    "file": "logs/flask.log",
    "max_size_mb": 5
  }
}
